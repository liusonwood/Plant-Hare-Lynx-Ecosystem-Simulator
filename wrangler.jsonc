{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "eco-simulator-agent",
  "compatibility_date": "2025-01-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      { "name": "ECO_CHAT", "class_name": "EcoChatAgent" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["EcoChatAgent"] }
  ],
  "vars": {
    "OPENAI_BASE_URL": "https://api.openai.com/v1",
    "OPENAI_MODEL": "gpt-4o-mini"
  },
  "observability": {
    "enabled": true
  }
}

# Cloudflare Worker 本地开发环境变量（请勿提交真实 key）
# 复制为 .dev.vars 后填入实际值
#
# OpenAI 兼容 API 的 base URL，例如：
#   官方:  https://api.openai.com/v1
#   第三方网关 / Ollama 等兼容端点
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名（需端点支持 tools / tool_choice）
OPENAI_MODEL=gpt-4o-mini

# API Key（敏感，请勿提交）
OPENAI_API_KEY=sk-your-key-here

# Cloudflare Worker 本地开发环境变量（请勿提交真实 key）
# 复制为 .dev.vars 后填入实际值
#
# OpenAI 兼容 API 的 base URL。以 NVIDIA Integrate API 为例：
#   https://integrate.api.nvidia.com/v1
# 也兼容官方 OpenAI、第三方网关、Ollama 等。
# 注意：不要带末尾 /，路径 /chat/completions 由程序自动拼接。
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# 模型名（需端点支持）。NVIDIA 示例：
#   stepfun-ai/step-3.7-flash
OPENAI_MODEL=stepfun-ai/step-3.7-flash

# API Key（敏感，请勿提交）。NVIDIA key 形如 nvapi-...
OPENAI_API_KEY=nvapi-your-key-here
